- $trackerRows = function ($rows) { return array_values(array_map(fn($row) => is_object($row) ? (array) $row : $row, $rows ?? [])); };
- $trackerGroups = [['type' => 'character', 'label' => 'Characters', 'items' => $trackerRows($tracker_character ?? [])], ['type' => 'corporation', 'label' => 'Corporations', 'items' => $trackerRows($tracker_corporation ?? [])], ['type' => 'alliance', 'label' => 'Alliances', 'items' => $trackerRows($tracker_alliance ?? [])], ['type' => 'faction', 'label' => 'Factions', 'items' => $trackerRows($tracker_faction ?? [])], ['type' => 'ship', 'label' => 'Ships', 'items' => $trackerRows($tracker_ship ?? [])], ['type' => 'group', 'label' => 'Groups', 'items' => $trackerRows($tracker_group ?? [])], ['type' => 'system', 'label' => 'Systems', 'items' => $trackerRows($tracker_system ?? [])], ['type' => 'constellation', 'label' => 'Constellations', 'items' => $trackerRows($tracker_constellation ?? [])], ['type' => 'region', 'label' => 'Regions', 'items' => $trackerRows($tracker_region ?? [])]];
- $trackerTotal = array_sum(array_map(fn($group) => count($group['items']), $trackerGroups));
- $dashboard = is_object($data['trackerDashboard'] ?? null) ? (array) $data['trackerDashboard'] : ($data['trackerDashboard'] ?? []);
- $trackerStats = is_object($dashboard['stats'] ?? null) ? (array) $dashboard['stats'] : ($dashboard['stats'] ?? []);
- $trackerDestroyed = is_object($trackerStats['destroyed'] ?? null) ? (array) $trackerStats['destroyed'] : ($trackerStats['destroyed'] ?? []);
- $trackerLost = is_object($trackerStats['lost'] ?? null) ? (array) $trackerStats['lost'] : ($trackerStats['lost'] ?? []);
- $trackerKills = $dashboard['kills'] ?? [];
- $trackerKillmailLimit = (int) ($dashboard['killmailLimit'] ?? 100);

h3.mb-3 Tracker

if ($trackerTotal == 0)
  .alert.alert-info Nothing is tracked yet.
else
  .table-responsive
    table.table.table-sm.table-striped.table-hover.align-middle.mb-3
      thead
        tr
          th(scope="col") Last 7 Days
          th.text-end(scope="col") Kills
          th.text-end(scope="col") ISK
          th.text-end(scope="col") Points
      tbody
        tr
          th.text-success(scope="row") Destroyed
          td.text-success.text-end.fw-bold(format="format-int-once" raw=($trackerDestroyed['count'] ?? 0))= number_format((float) ($trackerDestroyed['count'] ?? 0), 0)
          td.text-success.text-end.fw-bold(format="format-isk-once" raw=($trackerDestroyed['isk'] ?? 0))= number_format((float) ($trackerDestroyed['isk'] ?? 0), 0)
          td.text-success.text-end.fw-bold(format="format-int-once" raw=($trackerDestroyed['points'] ?? 0))= number_format((float) ($trackerDestroyed['points'] ?? 0), 0)
        tr
          th.text-danger(scope="row") Lost
          td.text-danger.text-end.fw-bold(format="format-int-once" raw=($trackerLost['count'] ?? 0))= number_format((float) ($trackerLost['count'] ?? 0), 0)
          td.text-danger.text-end.fw-bold(format="format-isk-once" raw=($trackerLost['isk'] ?? 0))= number_format((float) ($trackerLost['isk'] ?? 0), 0)
          td.text-danger.text-end.fw-bold(format="format-int-once" raw=($trackerLost['points'] ?? 0))= number_format((float) ($trackerLost['points'] ?? 0), 0)
  - $killListTitle = 'Tracked Killmails - Last 7 Days, Latest ' . $trackerKillmailLimit;
  - $killList = $trackerKills;
  if (count($killList) == 0)
    h3= $killListTitle
    .alert.alert-info No tracked killmails found in the last 7 days.
  else
    include ../components/kill_list.pug
  h4.mt-4 Manage Tracker
  .table-responsive
    table.table.table-sm.table-striped.table-hover.align-middle
      thead
        tr
          th Entity
          th Type
          th.text-end Action
      tbody
        each $group in $trackerGroups
          if (!empty($group['items']))
            tr.table-active
              th(colspan="3")= $group['label']
            each $item in $group['items']
              - $type = $group['type'];
              - $id = (int) ($item['id'] ?? 0);
              - $name = (string) ($item['name'] ?? '');
              - $displayName = rtrim($name, ' *');
              - $isProtected = ($type == 'character' && $id == (int) ($characterID ?? 0)) || ($type == 'corporation' && $id == (int) ($corporationID ?? 0)) || ($type == 'alliance' && $id == (int) ($allianceID ?? 0)) || str_ends_with($name, ' *');
              - $hrefType = $type;
              - $field = ['id' => $id, 'name' => $displayName, 'characterID' => $id, 'characterName' => $displayName, 'corporationID' => $id, 'corporationName' => $displayName, 'allianceID' => $id, 'allianceName' => $displayName, 'factionID' => $id, 'factionName' => $displayName, 'shipTypeID' => $id, 'shipName' => $displayName, 'groupID' => $id, 'groupName' => $displayName, 'solarSystemID' => $id, 'solarSystemName' => $displayName, 'constellationID' => $id, 'constellationName' => $displayName, 'regionID' => $id, 'regionName' => $displayName];
              tr(data-tracker-row=($type . '-' . $id))
                td
                  .d-flex.align-items-center.gap-2
                    .text-center.flex-shrink-0(style="width: 34px;")
                      if ($type == 'character')
                        include ../components/image_char.pug
                      elseif ($type == 'corporation')
                        include ../components/image_corp.pug
                      elseif ($type == 'alliance')
                        include ../components/image_alli.pug
                      elseif ($type == 'faction')
                        include ../components/image_faction.pug
                      elseif ($type == 'ship')
                        include ../components/image_ship.pug
                      elseif ($type == 'system')
                        include ../components/image_system.pug
                      elseif ($type == 'constellation')
                        include ../components/image_constellation.pug
                      elseif ($type == 'region')
                        include ../components/image_region.pug
                      else
                        i.fas.fa-crosshairs
                    a(href=('/' . $hrefType . '/' . $id . '/'))= $displayName
                td.text-muted= ucfirst($type)
                td.text-end
                  if ($isProtected)
                    span.badge.bg-secondary(role="status" aria-label=($displayName . ' is pinned to your tracker')) Pinned
                  else
                    a.btn.btn-link.btn-sm.text-danger.p-0(href=('/account/tracker/' . $type . '/' . $id . '/remove/') rel="nofollow" aria-label=('Remove ' . $displayName . ' from tracker') title="Remove from Tracker")
                      i.fa.fa-minus(aria-hidden="true")
