extends base.pug

block vars
  - $pageTitle = 'Battle Reports Listing';

block title
  include components/title.pug

block content
  h2 Saved Battle Reports Listing
  table.table
    tr
      th(colspan="3") &nbsp;
      th(colspan="4" style="text-align: center;") Team A
      th(colspan="4" style="text-align: center;") Team B
    tr
      th Battle ID
      th Time
      th System / Region
      th(style="text-align: right;") Pilots
      th(style="text-align: right;") Ships
      th(style="text-align: right;") Points
      th(style="text-align: right;") ISK
      th(style="text-align: right;") Pilots
      th(style="text-align: right;") Ships
      th(style="text-align: right;") Points
      th(style="text-align: right;") ISK
    each $battle in ($battles ?? [])
      - $teamA = $battle['teamA'] ?? [];
      - $teamB = $battle['teamB'] ?? [];
      tr
        td
          a(href=('/br/' . ($battle['battleID'] ?? '')))= $battle['battleID'] ?? ''
        td= $battle['killTime'] ?? ''
        td
          a(href=('/system/' . ($battle['solarSystemID'] ?? 0) . '/'))= $battle['solarSystemName'] ?? ''
          |  / 
          a(href=('/region/' . ($battle['regionID'] ?? 0) . '/'))= $battle['regionName'] ?? ''
        td(class=(($teamA['pilotCount'] ?? 0) > ($teamB['pilotCount'] ?? 0) ? 'green' : 'red') style="text-align: right")= number_format((float) ($teamA['pilotCount'] ?? 0), 0)
        td(class=(($teamA['totalShips'] ?? 0) > ($teamB['totalShips'] ?? 0) ? 'green' : 'red') style="text-align: right")= number_format((float) ($teamA['totalShips'] ?? 0), 0)
        td(class=(($teamA['total_points'] ?? 0) < ($teamB['total_points'] ?? 0) ? 'green' : 'red') style="text-align: right")= number_format((float) ($teamA['total_points'] ?? 0), 0)
        td(class=(($teamA['total_price'] ?? 0) < ($teamB['total_price'] ?? 0) ? 'green' : 'red') style="text-align: right")= $formatIsk($teamA['total_price'] ?? 0)
        td(class=(($teamA['pilotCount'] ?? 0) < ($teamB['pilotCount'] ?? 0) ? 'green' : 'red') style="text-align: right")= number_format((float) ($teamB['pilotCount'] ?? 0), 0)
        td(class=(($teamA['totalShips'] ?? 0) < ($teamB['totalShips'] ?? 0) ? 'green' : 'red') style="text-align: right")= number_format((float) ($teamB['totalShips'] ?? 0), 0)
        td(class=(($teamA['total_points'] ?? 0) > ($teamB['total_points'] ?? 0) ? 'green' : 'red') style="text-align: right")= number_format((float) ($teamB['total_points'] ?? 0), 0)
        td(class=(($teamA['total_price'] ?? 0) > ($teamB['total_price'] ?? 0) ? 'green' : 'red') style="text-align: right")= $formatIsk($teamB['total_price'] ?? 0)
