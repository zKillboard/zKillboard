extends base.pug

block vars
  - $pageTitle = 'Favorites';

block title
  include components/title.pug

block content
  h3 Favorites
  if (count($kills ?? []) == 0)
    p No favorites found.
  else
    - $killList = $kills;
    include components/kill_list.pug
  hr
  strong
    i To add favorites, go to a killmail and click the star. Same thing to remove the killmail from your favorites.
  br
  img(src="/img/favorites_example.png" alt="Favorites Example")
