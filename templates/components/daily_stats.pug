            var handleName = handle.getAttribute("data-handle");
            var padX = parseFloat(graph.getAttribute("data-pad-x") || "18");
            var graphWidth = parseFloat(graph.getAttribute("data-graph-width") || "1164");
            var viewWidth = parseFloat(graph.getAttribute("data-view-width") || "1200");
            var leftShade = svg.querySelector(".daily-range-left-shade");
            var rightShade = svg.querySelector(".daily-range-right-shade");
