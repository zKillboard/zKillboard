            var start = graph.getAttribute("data-range-start");
            var end = graph.getAttribute("data-range-end");
            var days = splitDays(graph.getAttribute("data-history-days"));
            var token = (start == days[0] && end == days[days.length - 1]) ? "all" : (start + ".." + end);
            var side = graph.getAttribute("data-current-side") || "kills";
            var url = (graph.getAttribute("data-base-url") || "") + encodeURIComponent(side) + "/" + token + "/";
