            var leftGuide = svg.querySelector(".daily-range-left-guide");
            var rightGuide = svg.querySelector(".daily-range-right-guide");
            var grips = svg.querySelectorAll(".daily-range-grip");
            var startIdx = Math.max(0, days.indexOf(graph.getAttribute("data-range-start")));
            var endIdx = Math.max(0, days.indexOf(graph.getAttribute("data-range-end")));
            if (endIdx < startIdx) endIdx = startIdx;
            var idxToX = function (idx) {
