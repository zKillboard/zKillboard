if (($key ?? '') == 'corporation' && (($taxRateIsk !== null || $taxRateLP !== null) || !empty($detailData['date_founded']) || ($creatorID > 1 && !empty($detailData['creatorName'])) || $homeStationID > 0 || array_key_exists('war_eligible', $detailData) || array_key_exists('friendly_fire', $detailData) || array_key_exists('friendly_fire_enabled', $detailData)))
  table.table.table-sm.table-borderless.mb-2(style="table-layout: fixed; width: 100%;")
    thead
      tr
        if ($taxRateIsk !== null || $taxRateLP !== null)
          th.text-truncate(scope="col") Tax Rates
        if (!empty($detailData['date_founded']))
          th.text-truncate(scope="col") Founded
        if ($creatorID > 1 && !empty($detailData['creatorName']))
          th.text-truncate(scope="col") Founder
        if ($homeStationID > 0)
          th.text-truncate(scope="col") Home Station
        if (array_key_exists('war_eligible', $detailData))
          th.text-truncate(scope="col") War Eligible
        if (array_key_exists('friendly_fire', $detailData) || array_key_exists('friendly_fire_enabled', $detailData))
          th.text-truncate(scope="col") Friendly Fire
    tbody
      tr
        if ($taxRateIsk !== null || $taxRateLP !== null)
          td.pe-3.text-truncate
            if ($taxRateIsk !== null)
              | ISK: 
              span(format="format-dec1" raw=$taxRateIsk)
              | %
            if ($taxRateIsk !== null && $taxRateLP !== null)
              |  / 
            if ($taxRateLP !== null)
              | LP: 
              span(format="format-dec1" raw=$taxRateLP)
              | %
