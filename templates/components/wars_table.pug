.war-list
  if (empty($wars))
    .war-empty No wars found.
  else
    each $war in $wars
      - $aggressor = $war['aggressor'] ?? [];
      - $defender = $war['defender'] ?? [];
      - $aggressorKills = $aggressor['ships_killed'] ?? 0;
      - $defenderKills = $defender['ships_killed'] ?? 0;
      - $aggressorIsk = $aggressor['isk_destroyed'] ?? ($aggressor['isk_killed'] ?? 0);
      - $defenderIsk = $defender['isk_destroyed'] ?? ($defender['isk_killed'] ?? 0);
      - $aggressorName = $aggressor['name'] ?? 'Unknown aggressor';
      - $defenderName = $defender['name'] ?? 'Unknown defender';
      - $aggressorID = $aggressor['alliance_id'] ?? ($aggressor['corporation_id'] ?? ($aggressor['id'] ?? 0));
      - $defenderID = $defender['alliance_id'] ?? ($defender['corporation_id'] ?? ($defender['id'] ?? 0));
      - $aggressorKind = isset($aggressor['alliance_id']) ? 'alliances' : 'corporations';
      - $defenderKind = isset($defender['alliance_id']) ? 'alliances' : 'corporations';
      a.war-row(href=('/war/' . ($war['id'] ?? '') . '/') aria-label=('War ' . $aggressorName . ' versus ' . $defenderName))
        .war-side.war-side-aggressor
          img(src=('https://images.evetech.net/' . $aggressorKind . '/' . $aggressorID . '/logo?size=64') alt="" loading="lazy" decoding="async" fetchpriority="low")
          .war-side-copy
            span.war-label Aggressor
            strong= $aggressorName
        .war-scoreboard
          .war-score-pair
            span(class=($aggressorKills >= $defenderKills ? 'green' : 'red') format="format-int-once" raw=$aggressorKills)= $shortNum($aggressorKills)
            small Kills
            span(class=($defenderKills >= $aggressorKills ? 'green' : 'red') format="format-int-once" raw=$defenderKills)= $shortNum($defenderKills)
          .war-score-pair
            span(class=($aggressorIsk >= $defenderIsk ? 'green' : 'red') format="format-isk-once" raw=$aggressorIsk)= $shortNum($aggressorIsk)
            small ISK
            span(class=($defenderIsk >= $aggressorIsk ? 'green' : 'red') format="format-isk-once" raw=$defenderIsk)= $shortNum($defenderIsk)
        .war-side.war-side-defender
          .war-side-copy
            span.war-label Defender
            strong= $defenderName
          img(src=('https://images.evetech.net/' . $defenderKind . '/' . $defenderID . '/logo?size=64') alt="" loading="lazy" decoding="async" fetchpriority="low")
