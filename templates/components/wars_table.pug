- $warListLabel = (($row['name'] ?? 'Wars') . ' wars');
.war-list.noclipboard(role="list" aria-label=$warListLabel)
  if (empty($wars))
    .war-empty No wars found.
  else
    .war-row.war-row-head(aria-hidden="true")
      .war-entity-cell Aggressor
      .war-num-cell Kills
      .war-num-cell ISK
      .war-num-cell Kills
      .war-num-cell ISK
      .war-entity-cell.war-defender-cell Defender
    each $war in $wars
      - $aggressor = $war['aggressor'] ?? [];
      - $defender = $war['defender'] ?? [];
      - $aggressorKills = $aggressor['ships_killed'] ?? 0;
      - $defenderKills = $defender['ships_killed'] ?? 0;
      - $aggressorIsk = $aggressor['isk_destroyed'] ?? ($aggressor['isk_killed'] ?? 0);
      - $defenderIsk = $defender['isk_destroyed'] ?? ($defender['isk_killed'] ?? 0);
      - $aggressorName = $aggressor['name'] ?? ($war['agrName'] ?? 'Unknown aggressor');
      - $defenderName = $defender['name'] ?? ($war['dfdName'] ?? 'Unknown defender');
      - $aggressorID = $aggressor['alliance_id'] ?? ($aggressor['corporation_id'] ?? ($aggressor['id'] ?? 0));
      - $defenderID = $defender['alliance_id'] ?? ($defender['corporation_id'] ?? ($defender['id'] ?? 0));
      - $aggressorKind = isset($aggressor['alliance_id']) ? 'alliances' : 'corporations';
      - $defenderKind = isset($defender['alliance_id']) ? 'alliances' : 'corporations';
      - $warLabel = 'War ' . $aggressorName . ' versus ' . $defenderName . ', aggressor ' . number_format((float) $aggressorKills, 0) . ' kills and ' . number_format((float) $aggressorIsk, 0) . ' ISK, defender ' . number_format((float) $defenderKills, 0) . ' kills and ' . number_format((float) $defenderIsk, 0) . ' ISK';
      .war-row(role="listitem" aria-label=$warLabel)
        a.war-entity-cell.war-entity-link(href=('/war/' . ($war['id'] ?? '') . '/') aria-label=('War ' . $aggressorName . ' versus ' . $defenderName))
          img(src=('https://images.evetech.net/' . $aggressorKind . '/' . $aggressorID . '/logo?size=64') alt=($aggressorName . ' logo') loading="lazy" decoding="async" fetchpriority="low")
          span= $aggressorName
        a.war-num-cell(href=('/war/' . ($war['id'] ?? '') . '/') class=($aggressorKills >= $defenderKills ? 'green' : 'red') format="format-int-once" raw=$aggressorKills aria-label=('Aggressor kills: ' . number_format((float) $aggressorKills, 0)))= $shortNum($aggressorKills)
        a.war-num-cell(href=('/war/' . ($war['id'] ?? '') . '/') class=($aggressorIsk >= $defenderIsk ? 'green' : 'red') format="format-isk-once" raw=$aggressorIsk aria-label=('Aggressor ISK destroyed: ' . number_format((float) $aggressorIsk, 0)))= $shortNum($aggressorIsk)
        a.war-num-cell(href=('/war/' . ($war['id'] ?? '') . '/') class=($defenderKills >= $aggressorKills ? 'green' : 'red') format="format-int-once" raw=$defenderKills aria-label=('Defender kills: ' . number_format((float) $defenderKills, 0)))= $shortNum($defenderKills)
        a.war-num-cell(href=('/war/' . ($war['id'] ?? '') . '/') class=($defenderIsk >= $aggressorIsk ? 'green' : 'red') format="format-isk-once" raw=$defenderIsk aria-label=('Defender ISK destroyed: ' . number_format((float) $defenderIsk, 0)))= $shortNum($defenderIsk)
        a.war-entity-cell.war-entity-link.war-defender-cell(href=('/war/' . ($war['id'] ?? '') . '/') aria-label=('War ' . $aggressorName . ' versus ' . $defenderName))
          span= $defenderName
          img(src=('https://images.evetech.net/' . $defenderKind . '/' . $defenderID . '/logo?size=64') alt=($defenderName . ' logo') loading="lazy" decoding="async" fetchpriority="low")
