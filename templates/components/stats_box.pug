- $statisticsData = is_object($statistics ?? null) ? (array) $statistics : ($statistics ?? []);
- $extraData = is_object($extra ?? null) ? (array) $extra : ($extra ?? []);
- $prevRanks = is_object($statisticsData['prevRanks'] ?? null) ? (array) $statisticsData['prevRanks'] : ($statisticsData['prevRanks'] ?? []);
- $moneyTitle = function ($prices) { $prices = is_object($prices ?? null) ? (array) $prices : ($prices ?? []); return '$' . number_format((float) ($prices['usd'] ?? 0), 2, '.', ',') . ' / ' . number_format((float) ($prices['eur'] ?? 0), 2, '.', ',') . ' euro / GBP ' . number_format((float) ($prices['gbp'] ?? 0), 2, '.', ','); };
- $eff = fn($destroyed, $lost) => (($destroyed + $lost) == 0 ? 100 : ($destroyed / ($destroyed + $lost)) * 100);
- $rank = fn($value) => (($value ?? 0) == 0 ? '-' : number_format((float) $value, 0));
- $trend = function ($current, $previous, $date) { if (($current ?? 0) == 0 || ($previous ?? 0) == 0) return ['fas fa-minus', '', '']; if ($current < $previous) return ['fas fa-arrow-up green', 'Ranked #' . number_format((float) $previous, 0) . ' on ' . $date, '']; if ($current > $previous) return ['fas fa-arrow-down red', 'Ranked #' . number_format((float) $previous, 0) . ' on ' . $date, '']; return ['fas fa-minus green', 'No change in rank...', '']; };
- $rankCell = function ($current, $previous, $date) use ($rank, $trend) { [$icon, $title] = $trend($current, $previous, $date); return '<strong>' . $rank($current) . '</strong> <small><span rel="tooltip" title="' . htmlspecialchars($title, ENT_QUOTES) . '" class="' . htmlspecialchars($icon, ENT_QUOTES) . '"></span></small>'; };
- $progressPair = function ($left, $leftLabel, $rightLabel) { $left = max(0, min(100, (float) $left)); $right = 100 - $left; return '<div class="progress" style="width: 100%; margin-bottom: 0px;"><div class="progress-bar progress-bar-danger" role="progressbar" aria-valuenow="' . $left . '" aria-valuemin="0" aria-valuemax="100" style="width: ' . $left . '%; background-color: #A90707;">' . ($left > 10 ? number_format($left, 0) . '%' : '') . '</div><div class="progress-bar" role="progressbar" aria-valuenow="' . $right . '" aria-valuemin="0" aria-valuemax="100" style="width: ' . $right . '%; background-color: #007800;">' . ($right > 10 ? number_format($right, 0) . '%' : '') . '</div></div><span class="red">' . $leftLabel . '</span><span class="float-end green">' . $rightLabel . '</span>'; };
