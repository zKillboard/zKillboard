          td.red(style="text-align: right" rel="tooltip" title=$moneyTitle($statisticsData[$prefix === '' ? 'iskLostUsdEurGbp' : $prefix . 'IskLostUsdEurGbp'] ?? []) format="format-isk" id=($prefix === '' ? 's-a-il' : false))= $formatIsk($iskLost)
          td.red(style="text-align: right" format="format-int" id=($prefix === '' ? 's-a-il-r' : false))= $rank($statisticsData[$prefix === '' ? 'iskLostRank' : $prefix . 'IskLostRank'] ?? 0)
          td(style="text-align: right" format="format-dec1" class=($iskEff >= 50 ? 'green' : 'red') id=($prefix === '' ? 's-a-i-e' : false))= number_format((float) $iskEff, 1)
          th(style="text-align: right;")
