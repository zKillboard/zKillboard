          td(style="text-align: right" format="format-dec1" class=($pointsEff >= 50 ? 'green' : 'red') id=($prefix === '' ? 's-a-p-e' : false))= number_format((float) $pointsEff, 1)
          th(style="text-align: right")= $rightLabel
        tr(class=$rowClass)
